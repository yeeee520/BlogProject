<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.springboot.mapper.UserMapper">
    <select id="selectManagerPage" resultType="com.example.springboot.entity.User">
        select username,fans,focus,photo from `user`
        where user_id=#{userId}


    </select>
    <select id="selectHeaderPage" resultType="com.example.springboot.entity.User">
        select username,photo from `user`
        where user_id=#{userId}

    </select>

</mapper>
